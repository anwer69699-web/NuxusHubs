-- ==========================================
-- == نظام اللوك السلس (Smooth) ==
-- ==========================================
local function ToggleLock()
    if _G.VoidV3_Cleanup then return end
    
    local hrp = GetHRP()
    if not hrp then
        LockOn = false
        SetBtnActive(false)
        return
    end

    LockOn = not LockOn
    SetBtnActive(LockOn)

    if LockOn then
        -- إعداد AngularVelocity
        pcall(function()
            local att = hrp:FindFirstChild("V3_Att") or Instance.new("Attachment", hrp)
            att.Name = "V3_Att"
            
            local av = hrp:FindFirstChild("V3_AV") or Instance.new("AngularVelocity", hrp)
            av.Name = "V3_AV"
            av.Attachment0 = att
            av.MaxTorque = math.huge
            av.ReactionTorqueEnabled = false
        end)

        LockConn = Track(RunService.Heartbeat:Connect(function(dt)
            if not LockOn or _G.VoidV3_Cleanup then return end
            
            local h = GetHRP()
            if not h or not h.Parent then
                LockOn = false
                SetBtnActive(false)
                if LockConn then
                    LockConn:Disconnect()
                    LockConn = nil
                end
                return
            end

            -- البحث عن أقرب لاعب
            local bestTarget = nil
            local bestHRP = nil
            local minDist = math.huge

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character then
                    local oh = plr.Character:FindFirstChild("HumanoidRootPart")
                    local hum = plr.Character:FindFirstChild("Humanoid")
                    if oh and hum and hum.Health > 0 then
                        local dist = (h.Position - oh.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            bestTarget = plr
                            bestHRP = oh
                        end
                    end
                end
            end

            if bestHRP then
                local dir = bestHRP.Position - h.Position
                local flatDir = Vector3.new(dir.X, 0, dir.Z)
                local yDiff = dir.Y

                -- سرعة أفقية سلسة
                local hSpeed = math.clamp(flatDir.Magnitude * 6, 0, 55)
                local hVel = flatDir.Magnitude > 0.5 and flatDir.Unit * hSpeed or Vector3.zero

                -- سرعة عمودية سلسة
                local vSpeed = 0
                if math.abs(yDiff) > 2 then
                    vSpeed = math.clamp(yDiff * 8, -60, 60)
                end

                local targetVel = Vector3.new(hVel.X, vSpeed, hVel.Z)
                
                -- Lerp سلس جداً (0.18 = سموث ممتاز)
                h.AssemblyLinearVelocity = h.AssemblyLinearVelocity:Lerp(targetVel, 0.18)

                -- دوران سلس
                pcall(function()
                    local av = h:FindFirstChild("V3_AV")
                    if av and flatDir.Magnitude > 1 then
                        local lookCF = CFrame.lookAt(h.Position, bestHRP.Position)
                        local rel = h.CFrame:ToObjectSpace(lookCF)
                        local axis, angle = rel:ToAxisAngle()
                        
                        if angle > 0.002 then
                            local worldAxis = h.CFrame:VectorToWorldSpace(axis)
                            local spin = math.clamp(angle * 12, 0, 12)
                            av.AngularVelocity = av.AngularVelocity:Lerp(
                                worldAxis * spin * Vector3.new(1, 1, 0.08), 0.25
                            )
                        else
                            av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.2)
                        end
                    else
                        local av = h:FindFirstChild("V3_AV")
                        if av then av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.2) end
                    end
                end)
            else
                -- لا يوجد هدف - توقف تدريجي
                h.AssemblyLinearVelocity = h.AssemblyLinearVelocity:Lerp(
                    Vector3.new(0, math.clamp(h.AssemblyLinearVelocity.Y, -5, 5), 0), 0.1
                )
                pcall(function()
                    local av = h:FindFirstChild("V3_AV")
                    if av then av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.15) end
                end)
            end
        end))
    else
        -- إيقاف اللوك
        if LockConn then
            LockConn:Disconnect()
            LockConn = nil
        end
        
        local h = GetHRP()
        if h then
            -- توقف سلس
            h.AssemblyLinearVelocity = h.AssemblyLinearVelocity:Lerp(Vector3.zero, 0.3)
            pcall(function()
                local av = h:FindFirstChild("V3_AV")
                if av then av.AngularVelocity = Vector3.zero end
            end)
        end
    end
end

-- ====== معالجة الضغط على الزر (مع نظام السحب) ======
LockBtn.MouseButton1Down:Connect(function()
    -- نسجل وقت الضغط
    local pressTime = tick()
    local pressPos = UserInputService:GetMouseLocation()
    
    -- ننتظر الـ InputEnded
    local endedConn
    endedConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or 
           input.UserInputType == Enum.UserInputType.MouseButton1 then
            
            endedConn:Disconnect()
            
            -- نتحقق: هل كان سحب ولا ضغطة؟
            local releasePos = input.Position
            local dragDist = (Vector2.new(releasePos.X, releasePos.Y) - pressPos).Magnitude
            local pressDuration = tick() - pressTime
            
            -- لو المسافة صغيرة والوقت قصير = ضغطة حقيقية
            if dragDist < dragThreshold * 1.5 and pressDuration < 0.4 then
                ToggleLock()
            end
        end
    end)
end)

