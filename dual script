repeat task.wait() until game:IsLoaded()

-- تنظيف آمن للنسخة القديمة
if _G.VoidRunning then
    _G.VoidRunning = false
    pcall(function()
        if _G.VoidLockConn then _G.VoidLockConn:Disconnect() end
        if _G.VoidSpeedConn then _G.VoidSpeedConn:Disconnect() end
        local h = game:GetService("Players").LocalPlayer.Character and game:GetService("Players").LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
