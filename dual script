_G.VoidV3_CleanupFunc = function()
    _G.VoidV3_Cleanup = true
    _G.VoidV3_Running = false
    LockOn = false
    
    if LockConn then LockConn:Disconnect() LockConn = nil end
    ClearCons()
    
    local h = GetHRP()
    if h then
        h.AssemblyLinearVelocity = Vector3.zero
        pcall(function()
            local av = h:FindFirstChild("V3_AV")
            if av then av.AngularVelocity = Vector3.zero end
        end)
    end
    
    pcall(function()
        for _, g in ipairs(CoreGui:GetChildren()) do
            if g.Name:find("VoidV3_") then
                g:Destroy()
            end
        end
    end)
end

