local S1 = game:GetService("Players")
local S2 = game:GetService("RunService")
local S3 = game:GetService("UserInputService")
local S5 = game:GetService("TweenService")
local S6 = game:GetService("CoreGui")
local LP = S1.LocalPlayer
local ScriptCore = true

local AllCon = {}
local function Track(c) table.insert(AllCon, c) return c end
local function DisAll() for _, c in ipairs(AllCon) do pcall(function() c:Disconnect() end) end AllCon = {} end

-- == إعدادات الثيم المتقدم (Neon Dark) ==
local Theme = {
    BG = Color3.fromRGB(8, 8, 14),
    Panel = Color3.fromRGB(16, 16, 26),
    Accent = Color3.fromRGB(0, 195, 255),
    AccentDark = Color3.fromRGB(0, 80, 120),
    Text = Color3.fromRGB(210, 215, 225),
    Success = Color3.fromRGB(0, 255, 170),
    Error = Color3.fromRGB(255, 60, 80),
}

local SC = math.clamp(math.min(workspace.CurrentCamera.ViewportSize.X / 1080, workspace.CurrentCamera.ViewportSize.Y / 1920), 0.9, 1.5)

-- == أدوات بناء الواجهة المتقدمة ==
local UI = {}
function UI:Corner(Parent, Rad)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, Rad or 12)
    c.Parent = Parent
    return c
end

function UI:Stroke(Parent, Color, Thick)
    local s = Instance.new("UIStroke")
    s.Thickness = Thick or 1.5
    s.Color = Color or Theme.Accent
    s.Transparency = 0.4
    s.Parent = Parent
    return s
end

function UI:Glow(Parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Theme.AccentDark),
        ColorSequenceKeypoint.new(0.5, Theme.Accent),
        ColorSequenceKeypoint.new(1, Theme.AccentDark)
    })
    g.Parent = Parent
    return g
end

function UI:FastTween(Inst, Props, Time, Style)
    return S5:Create(Inst, TweenInfo.new(Time or 0.2, Style or Enum.EasingStyle.Quart, Enum.EasingDirection.Out), Props)
end

-- == المتغيرات الآمنة ==
local LKA = false
local LockConn = nil
local Ky = { LK = Enum.KeyCode.X }

local function gH()
    local c = LP.Character
    if not c then return nil end
    return c:FindFirstChild("HumanoidRootPart")
end

