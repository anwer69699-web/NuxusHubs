-- ==========================================
-- == نظام اللوك الجديد (محمي 100% ضد الأخطاء) ==
-- ==========================================
local function tLK()
    -- التأكد من وجود الشخصية أولاً
    local h = gH()
    if not h then LKA = false return end

    LKA = not LKA

    -- تحديث الواجهة بأمان
    pcall(function()
        LockBtn.TextColor3 = LKA and Theme.Success or Theme.Text
        StatusIndicator.BackgroundColor3 = LKA and Theme.Success or Theme.Error
        if LKA then
            UI:FastTween(LockBtn, {Size = UDim2.new(0, 115*SC, 0, 115*SC)}, 0.1):Play()
            UI:FastTween(LockBtn, {Size = UDim2.new(0, 120*SC, 0, 120*SC)}, 0.15, Enum.EasingStyle.Back):Play()
        end
    end)

    if LKA then
        -- إعداد التثبيت
        pcall(function()
            local att = h:FindFirstChild("V_Att") or Instance.new("Attachment", h)
            att.Name = "V_Att"
            local av = h:FindFirstChild("V_AngVel") or Instance.new("AngularVelocity", h)
            av.Name = "V_AngVel"
            av.Attachment0 = att
            av.MaxTorque = math.huge
            av.ReactionTorqueEnabled = false
            av.Parent = h
        end)

        LockConn = Track(S2.Heartbeat:Connect(function(dt)
            if not LKA or not ScriptCore then return end
            
            -- إعادة التحقق من الوجود في كل فريم (يمنع الكراش 100%)
            local h = gH()
            if not h or not h.Parent then
                LKA = false
                if LockConn then LockConn:Disconnect() LockConn = nil end
                pcall(function() StatusIndicator.BackgroundColor3 = Theme.Error end)
                return
            end

            local target, targetHrp = nil, nil
            local minDist = math.huge
            
            for _, p in ipairs(S1:GetPlayers()) do
                if p ~= LP and p.Character then
                    local o = p.Character:FindFirstChild("HumanoidRootPart")
                    local hum = p.Character:FindFirstChild("Humanoid")
                    if o and hum and hum.Health > 0 then
                        local dist = (h.Position - o.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            target = p
                            targetHrp = o
                        end
                    end
                end
            end

            if target and targetHrp then
                -- فيزياء الحركة السلسة
                local dir = targetHrp.Position - h.Position
                local yDiff = dir.Y
                local flatDir = Vector3.new(dir.X, 0, dir.Z)

                -- التحكم الأفقي السلس
                local targetSpeed = math.clamp(flatDir.Magnitude * 8, 0, 65)
                local moveDir = flatDir.Magnitude > 0.5 and flatDir.Unit * targetSpeed or Vector3.new(0,0,0)

                -- التحكم العمودي السلس
                local ySpeed = 0
                if math.abs(yDiff) > 1 then
                    ySpeed = math.clamp(yDiff * 12, -75, 75)
                end

                local finalVel = Vector3.new(moveDir.X, ySpeed, moveDir.Z)

                -- استخدام Lerp لمنع الإهتزاز نهائياً
                h.AssemblyLinearVelocity = h.AssemblyLinearVelocity:Lerp(finalVel, 0.25)

                -- الدوران السلس
                pcall(function()
                    local av = h:FindFirstChild("V_AngVel")
                    if av and flatDir.Magnitude > 0.5 then
                        local lookAt = CFrame.lookAt(h.Position, targetHrp.Position)
                        local relCF = h.CFrame:ToObjectSpace(lookAt)
                        local axis, angle = relCF:ToAxisAngle()

                        if angle > 0.001 then
                            local spinSpeed = math.clamp(angle * 15, 0, 15)
                            local worldAxis = h.CFrame:VectorToWorldSpace(axis)
                            av.AngularVelocity = av.AngularVelocity:Lerp(worldAxis * spinSpeed * Vector3.new(1, 1, 0.1), 0.3)
                        else
                            -- تهدئة الدوران تماماً عند الاستقامة
                            av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.15)
                        end
                    else
                        av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.15)
                    end
                end)
            else
                -- التوقف التدريجي عند فقدان الهدف
                h.AssemblyLinearVelocity = h.AssemblyLinearVelocity:Lerp(Vector3.new(0, h.AssemblyLinearVelocity.Y > 5 and 10 or 0, 0), 0.1)
                pcall(function()
                    local av = h:FindFirstChild("V_AngVel")
                    if av then av.AngularVelocity = av.AngularVelocity:Lerp(Vector3.zero, 0.1) end
                end)
            end
        end)
    else
        -- إلغاء اللوك
        if LockConn then LockConn:Disconnect() LockConn = nil end
        
        -- إيقاف سلس بدون تيبط
        local h = gH()
        if h then
            UI:FastTween(h, {AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y > 5 and 10 or 0, 0)}, 0.5, Enum.EasingStyle.Quad):Play()
        end
    end
end

LockBtn.MouseButton1Click:Connect(tLK)

-- == الهوتكي ==
Track(S3.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Ky.LK then tLK() end
end))

-- == إعادة التشغيل الآمنة عند الريسباون ==
LP.CharacterAdded:Connect(function(char)
    task.wait(1)
    -- إيقاف الحركة القديمة إن وجدت
    if LKA then 
        LKA = false 
        if LockConn then LockConn:Disconnect() LockConn = nil end 
    end
    -- لا يعيد تشغيله تلقائياً عشان اللاعب يتحكم
end)

-- == التنظيف الفاخر عند الخروج النهائي ==
local function cleanup()
    ScriptCore = false
    _G.VoidRunning = false
    LKA = false
    DisAll()
    if LockConn then LockConn:Disconnect() end
    local h = gH() if h then h.AssemblyLinearVelocity = Vector3.new(0,0,0) end
    pcall(function()
        for _, g in ipairs(S6:GetChildren()) do
            if g:GetAttribute("VoidAuth") then g:Destroy() end
        end
    end)
end
